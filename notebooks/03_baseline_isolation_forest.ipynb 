      "cell_type": "code",
      "source": [
        "from sklearn.ensemble import IsolationForest\n",
        "\n",
        "# Train Isolation Forest\n",
        "print(\"Training Isolation Forest...\")\n",
        "model = IsolationForest(\n",
        "    n_estimators=100,\n",
        "    contamination=0.0258,\n",
        "    random_state=42,\n",
        "    n_jobs=-1\n",
        ")\n",
        "model.fit(X)\n",
        "print(\"Training complete.\")"
